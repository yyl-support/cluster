apiVersion: batch.volcano.sh/v1alpha1
kind: Job
metadata:
    generateName: testorg-testrepo-test37-
    labels:
        jobPRID: "37"
        jobRepositoryName: testorg-testrepo-test37
        kubernetes.io/arch: amd64
        pipeline/run-id: test-delay-exit-123
spec:
    maxRetry: 1
    minAvailable: 1
    policies:
        - action: AbortJob
          event: PodFailed
    queue: shared-flexible-queue
    tasks:
        - maxRetry: 1
          name: main-script
          replicas: 1
          template:
            spec:
                activeDeadlineSeconds: 14400
                containers:
                    - args:
                        - |
                          git config --global url."http://git-cache-http-server.git-cache.svc.cluster.local:8080".insteadOf "https://gitcode.com" || echo "WARNING: git config failed for gitcode"
                          git config --global url."http://git-cache-github.git-cache.svc.cluster.local:8080".insteadOf "https://gh-proxy.test.osinfra.cn/https://github.com" || echo "WARNING: git config failed for github"
                          git config --global url."http://git-cache-gitee.git-cache.svc.cluster.local:8080".insteadOf "https://gitee.com" || echo "WARNING: git config failed for gitee"
                          git config --global url."http://git-cache-atomgit.git-cache.svc.cluster.local:8080".insteadOf "https://atomgit.com" || echo "WARNING: git config failed for atomgit"
                          git config --global url."http://git-cache-codehub.git-cache.svc.cluster.local:8080".insteadOf "https://codehub.devcloud.cn-north-4.huaweicloud.com" || echo "WARNING: git config failed for codehub"

                          trap 'EXIT_CODE=$?; [ "$EXIT_CODE" -ne 0 ] && sleep 20' EXIT
                          #!/bin/bash
                          echo "delay exit test"
                          exit 1
                      command:
                        - bash
                        - -c
                      env:
                        - name: WORKSPACE
                          value: /workspace
                        - name: workspace
                          value: /workspace
                        - name: GOPROXY
                          value: http://cache-service.nginx-pypi-cache.svc.cluster.local:8084|https://goproxy.cn|direct
                        - name: GOSUMDB
                          value: sum.golang.google.cn
                        - name: JOB_ID
                          value: job-delay-exit
                        - name: BUILDNUMBER
                          value: "202407"
                        - name: MAX_JOBS
                          value: "1"
                        - name: CMAKE_BUILD_PARALLEL_LEVEL
                          value: "1"
                      image: swr.cn-southwest-2.myhuaweicloud.com/base_image/python:3.11
                      name: ascend
                      resources:
                        limits:
                            cpu: "1"
                            memory: 1Gi
                        requests:
                            cpu: "1"
                            memory: 1Gi
                      workingDir: /workspace
                imagePullSecrets:
                    - name: huawei-swr-image-pull-secret-model-gy
                nodeSelector:
                    kubernetes.io/arch: amd64
                restartPolicy: Never
                securityContext:
                    runAsUser: 0
    ttlSecondsAfterFinished: 1800
